# Environment Variables untuk Kontrakan V2
# Copy file ini menjadi .env.local atau .env
# Jangan pernah commit file .env asli ke GitHub

# =========================================
# DATABASE
# =========================================
DATABASE_URL=postgresql://username:password@host:5432/database
# Legacy fallback masih didukung, tapi lebih dianjurkan pakai DATABASE_URL:
# SUPABASE_DB_HOST=
# SUPABASE_DB_PORT=6543
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=

# =========================================
# JWT
# =========================================
JWT_SECRET=replace_with_random_secret_min_32_chars

# =========================================
# CLOUDINARY
# =========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =========================================
# WEB PUSH / NOTIFICATION
# =========================================
VAPID_PUBLIC_KEY=your_public_key
VAPID_PRIVATE_KEY=your_private_key
VAPID_SUBJECT=mailto:admin@example.com

# =========================================
# APP
# =========================================
NODE_ENV=development
